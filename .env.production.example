# =============================================================================
# VZY OTT Verification Agent — Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control!
# =============================================================================

# --- Domain (your registered domain) ---
DOMAIN=YOUR_DOMAIN.com

# --- AI/LLM ---
OPENAI_API_KEY=sk-proj-...your-key-here...

# --- Database (auto-configured by docker-compose.prod.yml) ---
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DATABASE_URL=postgresql://vzy:${DB_PASSWORD}@postgres:5432/vzy_agent

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT Secret (generate with: openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_TO_64_CHAR_HEX_SECRET

# --- Scan Target ---
SCAN_TARGET_URL=https://www.watcho.com
SCAN_PLATFORM=both

# --- Schedule ---
SCAN_CRON=0 2 * * *
SCAN_TIMEZONE=Asia/Kolkata

# --- Email Notifications (Outlook SMTP) ---
EMAIL_RECIPIENTS=your-email@outlook.com
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-outlook-password

# --- Slack (optional) ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#ott-monitoring

# --- Jira (optional) ---
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# --- Webhook ---
WEBHOOK_PORT=9090
DEPLOY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# --- Dashboard ---
DASHBOARD_PORT=3000

# --- Grafana (optional) ---
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs
